{
	"compilerOptions": {
		"lib": [
			"ESNext"
		],
		"paths": {
			"slack.ts": [
				"./src/index.ts"
			],
			"slack.ts/rich": [
				"./src/exports/rich.ts"
			]
		},
		"target": "ESNext",
		"module": "Preserve",
		"moduleDetection": "force",
		"moduleResolution": "bundler",
		"allowImportingTsExtensions": true,
		"verbatimModuleSyntax": true,
		"noEmit": true,
		"strict": true,
		"skipLibCheck": true,
		"noFallthroughCasesInSwitch": true,
		"noUncheckedIndexedAccess": true,
		"noImplicitOverride": true
	}
}